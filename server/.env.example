# Copy this file to server/.env.local and adjust values.
# start-backend-if-needed.js auto-loads server/.env.local then server/.env.

# Option 1 (recommended): exported cookies.txt path
# YTDLP_COOKIES_PATH=C:\\path\\to\\cookies.txt

# Option 2: cookies content directly (single-line or escaped newlines)
# YTDLP_COOKIES_CONTENT=

# Option 3: base64-encoded cookies.txt
# YTDLP_COOKIES_B64=

# Option 4: read cookies directly from browser profile
# Supported by yt-dlp: chrome, edge, firefox, brave, opera...
# You can provide one or multiple values separated by commas.
YTDLP_COOKIES_FROM_BROWSER=chrome,edge,firefox
